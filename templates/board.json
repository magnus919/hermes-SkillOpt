{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "SkillOpt Board Metadata",
    "description": "Metadata for a single SkillOpt optimization run",
    "type": "object",
    "required": ["target", "skill_name", "board_slug", "training_count", "validation_count", "edit_budget", "epoch", "created_at", "baseline_snapshot", "status"],
    "properties": {
        "target": {"type": "string", "description": "Absolute path to the target SKILL.md"},
        "skill_name": {"type": "string", "description": "Name of the skill being optimized"},
        "board_slug": {"type": "string", "pattern": "^SkillOpt-", "description": "Kanban board slug"},
        "training_count": {"type": "integer", "minimum": 1},
        "validation_count": {"type": "integer", "minimum": 1},
        "edit_budget": {"type": "integer", "default": 4, "minimum": 1, "maximum": 16},
        "initial_edit_budget": {"type": "integer", "default": 4, "minimum": 1, "maximum": 16},
        "budget_floor": {"type": "integer", "default": 2, "minimum": 1, "maximum": 16},
        "max_epochs": {"type": "integer", "default": 4, "minimum": 1},
        "metric_weights": {
            "type": "object",
            "description": "Relative weights for multi-objective validation. Values are normalized before scoring.",
            "properties": {
                "pass_rate": {"type": "number", "default": 0.55, "minimum": 0},
                "quality_score": {"type": "number", "default": 0.30, "minimum": 0},
                "speed_score": {"type": "number", "default": 0.10, "minimum": 0},
                "token_efficiency": {"type": "number", "default": 0.05, "minimum": 0}
            },
            "additionalProperties": false
        },
        "epoch": {"type": "integer", "minimum": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "baseline_snapshot": {"type": "string", "description": "Filename of the baseline snapshot"},
        "status": {"type": "string", "enum": ["active", "completed", "archived"]}
    }
}
