{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Test Suite Definition",
    "description": "Describes a set of training or validation tasks for a SkillOpt run",
    "type": "object",
    "required": ["type", "tasks"],
    "properties": {
        "type": {
            "type": "string",
            "enum": ["training", "validation"],
            "description": "Whether this is a training or validation suite"
        },
        "skill_target": {
            "type": "string",
            "description": "Path to the skill being tested"
        },
        "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["id", "instruction", "success_criteria"],
                "properties": {
                    "id": {"type": "string", "description": "Unique task identifier"},
                    "instruction": {"type": "string", "description": "What the LLM should do"},
                    "input_data": {"type": "string", "description": "Optional input to the task"},
                    "expected_outcome": {"type": "string", "description": "What success looks like"},
                    "success_criteria": {"type": "string", "description": "How to evaluate the output"},
                    "tags": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "Tags for categorizing tasks"
                    }
                }
            }
        }
    }
}
